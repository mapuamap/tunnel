@using TunnelManager.Web.Models
@using Logger_MM.Agent
@inject NginxService NginxService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LoggerMMAgent? LoggerMM
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_forward.Domain" Label="Domain" Required="true" Variant="Variant.Outlined" />
        <MudTextField @bind-Value="_forward.Target" Label="Target (IP:PORT)" Required="true" Variant="Variant.Outlined" HelperText="Example: 192.168.66.142:5000" />
        <MudSwitch T="bool" @bind-Value="_forward.HasWebSocket" Label="WebSocket" Color="Color.Primary" UncheckedColor="Color.Default" Class="mt-3" />
        <MudSwitch T="bool" @bind-Value="_getSsl" Label="SSL Certificate" Color="Color.Success" UncheckedColor="Color.Default" Class="mt-1" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ForwardConfig Forward { get; set; } = new();

    private ForwardConfig _forward = new();
    private bool _getSsl = false;
    private bool _isEdit = false;

    protected override void OnInitialized()
    {
        if (Forward != null)
        {
            _forward = new ForwardConfig
            {
                Domain = Forward.Domain,
                Target = Forward.Target,
                HasWebSocket = Forward.HasWebSocket,
                HasSsl = Forward.HasSsl,
                IsEnabled = Forward.IsEnabled,
                HasAuth = Forward.HasAuth
            };
        }
        _isEdit = !string.IsNullOrEmpty(_forward.Domain);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Save()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User.Identity?.Name ?? "unknown";
        
        try
        {
            if (string.IsNullOrWhiteSpace(_forward.Domain) || string.IsNullOrWhiteSpace(_forward.Target))
            {
                Snackbar.Add("Domain and Target are required", Severity.Warning);
                LoggerMM?.Warning("ForwardEdit", "Save", "Validation failed: Domain and Target are required",
                    user: user,
                    @params: new { domain = _forward.Domain, target = _forward.Target },
                    tags: new[] { "forward", "validation" });
                return;
            }

            if (!System.Text.RegularExpressions.Regex.IsMatch(_forward.Target, @"^\d+\.\d+\.\d+\.\d+:\d+$"))
            {
                Snackbar.Add("Target must be in format IP:PORT", Severity.Warning);
                LoggerMM?.Warning("ForwardEdit", "Save", "Validation failed: Invalid target format",
                    user: user,
                    @params: new { domain = _forward.Domain, target = _forward.Target },
                    tags: new[] { "forward", "validation" });
                return;
            }

            if (_isEdit)
            {
                NginxService.UpdateForward(_forward.Domain, _forward);
                Snackbar.Add($"Forward {_forward.Domain} updated", Severity.Success);
                
                LoggerMM?.UserAction("ForwardEdit", "Save", $"Forward updated: {_forward.Domain}",
                    user: user,
                    @params: new { domain = _forward.Domain, target = _forward.Target, hasWebSocket = _forward.HasWebSocket },
                    tags: new[] { "forward", "update", "user-action" });
            }
            else
            {
                NginxService.CreateForward(_forward, _getSsl);
                Snackbar.Add($"Forward {_forward.Domain} created", Severity.Success);
                
                LoggerMM?.UserAction("ForwardEdit", "Save", $"Forward created: {_forward.Domain}",
                    user: user,
                    @params: new { domain = _forward.Domain, target = _forward.Target, hasWebSocket = _forward.HasWebSocket, sslRequested = _getSsl },
                    tags: new[] { "forward", "create", "user-action" });
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            LoggerMM?.Error("ForwardEdit", "Save", $"Failed to save forward: {ex.Message}",
                user: user,
                exception: ex,
                @params: new { domain = _forward.Domain, target = _forward.Target, isEdit = _isEdit },
                tags: new[] { "forward", "save", "error" });
        }
    }
}
