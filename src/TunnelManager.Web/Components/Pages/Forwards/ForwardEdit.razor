@using TunnelManager.Web.Models
@using Logger_MM.Agent
@inject NginxService NginxService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject LoggerMMAgent? LoggerMM
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_domain" Label="Domain" Required="true" Variant="Variant.Outlined" Disabled="_isEdit" />
        <MudTextField @bind-Value="_target" Label="Target (IP:PORT)" Required="true" Variant="Variant.Outlined" HelperText="Example: 192.168.66.142:5000" />
        <MudSwitch T="bool" Checked="@_hasWebSocket" CheckedChanged="@((bool val) => { _hasWebSocket = val; StateHasChanged(); })" Label="WebSocket" Color="Color.Primary" UncheckedColor="Color.Default" Class="mt-3" />
        <MudSwitch T="bool" Checked="@_getSsl" CheckedChanged="@((bool val) => { _getSsl = val; StateHasChanged(); })" Label="SSL Certificate" Color="Color.Success" UncheckedColor="Color.Default" Class="mt-1" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save" Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <text>Saving...</text>
            }
            else
            {
                <text>Save</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ForwardConfig Forward { get; set; } = new();

    private string _domain = string.Empty;
    private string _target = string.Empty;
    private bool _hasWebSocket = false;
    private bool _getSsl = false;
    private bool _isEdit = false;
    private bool _saving = false;
    private bool _hadSsl = false;

    protected override void OnInitialized()
    {
        if (Forward != null && !string.IsNullOrEmpty(Forward.Domain))
        {
            _domain = Forward.Domain;
            _target = Forward.Target;
            _hasWebSocket = Forward.HasWebSocket;
            _getSsl = Forward.HasSsl;
            _hadSsl = Forward.HasSsl;
            _isEdit = true;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Save()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User.Identity?.Name ?? "unknown";
        
        try
        {
            if (string.IsNullOrWhiteSpace(_domain) || string.IsNullOrWhiteSpace(_target))
            {
                Snackbar.Add("Domain and Target are required", Severity.Warning);
                LoggerMM?.Warning("ForwardEdit", "Save", "Validation failed: Domain and Target are required",
                    user: user,
                    @params: new { domain = _domain, target = _target },
                    tags: new[] { "forward", "validation" });
                return;
            }

            if (!System.Text.RegularExpressions.Regex.IsMatch(_target, @"^\d+\.\d+\.\d+\.\d+:\d+$"))
            {
                Snackbar.Add("Target must be in format IP:PORT", Severity.Warning);
                LoggerMM?.Warning("ForwardEdit", "Save", "Validation failed: Invalid target format",
                    user: user,
                    @params: new { domain = _domain, target = _target },
                    tags: new[] { "forward", "validation" });
                return;
            }

            _saving = true;
            StateHasChanged();
            
            // Small delay to let UI update
            await Task.Delay(50);

            var config = new ForwardConfig
            {
                Domain = _domain,
                Target = _target,
                HasWebSocket = _hasWebSocket,
                HasSsl = _getSsl,
                HasAuth = Forward?.HasAuth ?? false,
                IsEnabled = Forward?.IsEnabled ?? true
            };

            LoggerMM?.Info("ForwardEdit", "Save", $"Saving forward: {_domain}",
                user: user,
                @params: new { domain = _domain, target = _target, hasWebSocket = _hasWebSocket, getSsl = _getSsl, hadSsl = _hadSsl, isEdit = _isEdit },
                tags: new[] { "forward", "save", "debug" });

            if (_isEdit)
            {
                NginxService.UpdateForward(_domain, config);
                
                Snackbar.Add($"Forward {_domain} updated", Severity.Success);
                
                // Request new SSL certificate if toggled on (separate try/catch so edit isn't lost)
                if (_getSsl && !_hadSsl)
                {
                    try
                    {
                        NginxService.RequestSsl(_domain);
                        Snackbar.Add($"SSL certificate obtained for {_domain}", Severity.Success);
                    }
                    catch (Exception sslEx)
                    {
                        Snackbar.Add($"Forward saved but SSL failed: {sslEx.Message}", Severity.Warning);
                        LoggerMM?.Error("ForwardEdit", "Save", $"SSL request failed for {_domain}: {sslEx.Message}",
                            user: user,
                            exception: sslEx,
                            @params: new { domain = _domain },
                            tags: new[] { "forward", "ssl", "warning" });
                    }
                }
                
                LoggerMM?.UserAction("ForwardEdit", "Save", $"Forward updated: {_domain}",
                    user: user,
                    @params: new { domain = _domain, target = _target, hasWebSocket = _hasWebSocket, hasSsl = _getSsl, sslChanged = _hadSsl != _getSsl },
                    tags: new[] { "forward", "update", "user-action" });
            }
            else
            {
                // Create forward without SSL first
                NginxService.CreateForward(config, false);
                Snackbar.Add($"Forward {_domain} created", Severity.Success);
                
                // Request SSL separately so forward creation isn't rolled back on SSL failure
                if (_getSsl)
                {
                    try
                    {
                        NginxService.RequestSsl(_domain);
                        Snackbar.Add($"SSL certificate obtained for {_domain}", Severity.Success);
                    }
                    catch (Exception sslEx)
                    {
                        Snackbar.Add($"Forward created but SSL failed: {sslEx.Message}", Severity.Warning);
                        LoggerMM?.Error("ForwardEdit", "Save", $"SSL request failed for new forward {_domain}: {sslEx.Message}",
                            user: user,
                            exception: sslEx,
                            @params: new { domain = _domain },
                            tags: new[] { "forward", "ssl", "warning" });
                    }
                }
                
                LoggerMM?.UserAction("ForwardEdit", "Save", $"Forward created: {_domain}",
                    user: user,
                    @params: new { domain = _domain, target = _target, hasWebSocket = _hasWebSocket, sslRequested = _getSsl },
                    tags: new[] { "forward", "create", "user-action" });
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            LoggerMM?.Error("ForwardEdit", "Save", $"Failed to save forward: {ex.Message}",
                user: user,
                exception: ex,
                @params: new { domain = _domain, target = _target, isEdit = _isEdit, hasWebSocket = _hasWebSocket, getSsl = _getSsl },
                tags: new[] { "forward", "save", "error" });
        }
        finally
        {
            _saving = false;
        }
    }
}
