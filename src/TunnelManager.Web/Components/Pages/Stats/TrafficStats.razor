    {
        _errorFilter = f;
        StateHasChanged();
    }

    private static int PickBucketMinutes(int? hours) => hours switch
    {
        null => 60 * 24,           // all → 1d
        <= 1 => 1,                 // 1h  → 1min
        <= 12 => 5,                // 12h → 5min
        <= 24 => 15,               // 24h → 15min
        <= 48 => 30,               // 48h → 30min
        <= 168 => 60,              // 7d  → 1h (hourly aggregate)
        _ => 60 * 4,               // 30d → 4h (hourly aggregate)
    };

    private static DateTime BucketStart(DateTime t, int bucketMinutes)
    {
        var u = t.Kind == DateTimeKind.Utc ? t : t.ToUniversalTime();
        var totalMin = (long)Math.Floor((u - DateTime.UnixEpoch).TotalMinutes);
        var snapped = totalMin - (totalMin % bucketMinutes);
        return DateTime.SpecifyKind(DateTime.UnixEpoch.AddMinutes(snapped), DateTimeKind.Utc);
    }

    private (List<TimeDataPoint> Requests, List<TimeDataPoint> Bytes) FillBucketGaps(
        List<TimeDataPoint> bucketed, int bucketMinutes)
    {
        if (bucketed.Count <= 1) return (bucketed, bucketed);
        var step = TimeSpan.FromMinutes(bucketMinutes);
        var first = bucketed.First().Time;
        var last = bucketed.Last().Time;
        var byKey = bucketed.ToDictionary(b => b.Time);
        var requests = new List<TimeDataPoint>();
        var bytes = new List<TimeDataPoint>();
        for (var t = first; t <= last; t = t.Add(step))
        {
            if (byKey.TryGetValue(t, out var p))
            {
                requests.Add(new TimeDataPoint { Time = t, Requests = p.Requests });
                bytes.Add(new TimeDataPoint { Time = t, Bytes = p.Bytes });
            }
            else
            {
                requests.Add(new TimeDataPoint { Time = t, Requests = 0 });
                bytes.Add(new TimeDataPoint { Time = t, Bytes = 0 });
            }
        }
        return (requests, bytes);
    }

    private static string ShortUa(string? ua)
    {
        if (string.IsNullOrWhiteSpace(ua) || ua == "-") return "—";
        // Common rough buckets: just return the first chunk for readability.
        var idx = ua.IndexOf(' ');
        return idx > 0 ? ua[..Math.Min(40, idx)] : ua[..Math.Min(40, ua.Length)];
    }

    private async Task ExportToCsv()
    {
        try
        {
            var csv = new System.Text.StringBuilder();
            csv.AppendLine("Domain,Timestamp,Requests,Bytes Sent,Bytes Received,2xx,3xx,4xx,5xx,Unique IPs");
            foreach (var s in _tableData)
            {
                csv.AppendLine($"{s.Domain},{s.Timestamp:yyyy-MM-dd HH:mm:ss},{s.Requests},{s.BytesSent},{s.BytesReceived},{s.Status2xx},{s.Status3xx},{s.Status4xx},{s.Status5xx},{s.UniqueIps}");
            }
            var fileName = $"traffic_stats_{DateTime.UtcNow:yyyyMMdd_HHmmss}.csv";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, csv.ToString());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Export failed: {ex.Message}";
            StateHasChanged();
        }
    }

    private void StartAutoRefresh()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(LoadData);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1) { order++; len /= 1024; }
        return $"{len:0.##} {sizes[order]}";
    }

    private static string TimeRangeLabel(int? hours) => hours switch
    {
        null => "all time",
        1 => "last hour",
        12 => "last 12h",
        24 => "last 24h",
        168 => "last 7 days",
        720 => "last 30 days",
        _ => $"last {hours}h",
    };

    private RenderFragment KpiCard(string title, string value, string icon, Color color) =>
    @<MudItem xs="12" sm="6" md="4" lg="2" @key="title">
        <MudPaper Outlined="true" Class="pa-3" Style="height:100%;">
            <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                <MudAvatar Color="@color" Variant="Variant.Filled" Size="Size.Medium">
                    <MudIcon Icon="@icon" />
                </MudAvatar>
                <div style="min-width:0;">
                    <MudText Typo="Typo.caption" Color="Color.Default" Style="text-transform:uppercase;letter-spacing:0.5px;">@title</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:600;line-height:1.2;">@value</MudText>
                </div>
            </MudStack>
        </MudPaper>
    </MudItem>;

    private RenderFragment StatusRow(string label, long value, Color color) =>
    @<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" @key="label">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudChip Size="Size.Small" Color="@color" Variant="Variant.Filled">@label</MudChip>
        </MudStack>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.body2">@value.ToString("N0")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">@(_statusData.Total > 0 ? (value * 100.0 / _statusData.Total).ToString("F1") : "0")%</MudText>
        </MudStack>
    </MudStack>;

    public void Dispose() => _refreshTimer?.Dispose();
}
