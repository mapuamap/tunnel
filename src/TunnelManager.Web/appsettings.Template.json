{
  "_comment": "Template — secret values come from .env at runtime (see docker-compose.prod.yml env_file). Use double-underscore keys in .env, e.g. Vps__Password.",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Vps": {
    "Host": "<from .env Vps__Host>",
    "User": "<from .env Vps__User>",
    "Password": "<from .env Vps__Password — optional fallback>",
    "PrivateKeyPath": "<from .env Vps__PrivateKeyPath — preferred>",
    "NginxConfigDir": "/etc/nginx/sites-available",
    "NginxEnabledDir": "/etc/nginx/sites-enabled",
    "NginxStreamDir": "/etc/nginx/stream.d",
    "SshTunnelPortRange": {
      "Min": 2222,
      "Max": 2299
    }
  },
  "Auth": {
    "Username": "<from .env Auth__Username>",
    "Password": "<from .env Auth__Password — legacy>",
    "PasswordHash": "<from .env Auth__PasswordHash — preferred after Stage 4>"
  },
  "ConnectionStrings": {
    "DefaultConnection": "<from .env ConnectionStrings__DefaultConnection>",
    "StatsConnection": "<from .env ConnectionStrings__StatsConnection>"
  },
  "LoggerMM": {
    "Url": "<from .env LoggerMM__Url>",
    "ApiKey": "<from .env LoggerMM__ApiKey>",
    "AppName": "TunnelManager"
  }
}
